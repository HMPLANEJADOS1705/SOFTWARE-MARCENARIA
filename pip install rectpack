from rectpack import newPacker

def otimizar_corte(pecas, largura_chapa, altura_chapa):
    # Inicializa o empacotador
    packer = newPacker(rotation=True) # rotation=True permite girar peças se não tiver fibra
    
    # Adiciona a chapa
    packer.add_bin(largura_chapa, altura_chapa)
    
    # Adiciona as peças
    for peca in pecas:
        packer.add_rect(peca['w'], peca['h'], rid=peca['id'])
        
    packer.pack()
    
    return packer.rect_list()

# --- Exemplo de Uso (Teste com 15mm) ---
chapa_15mm = {'w': 2750, 'h': 1840}
pecas_projeto = [
    {'id': 'P1', 'w': 1000, 'h': 500},
    {'id': 'P2', 'w': 1200, 'h': 600},
    {'id': 'P3', 'w': 800, 'h': 400}
]

# --- PASSO 3: Salvar e Validar o Resultado Matemático ---
print("\n--- Resultados da Otimização Matemático ---")
# Recupera a lista de retângulos (pecas) encaixadas
# O resultado vem como: (bin_index, x, y, w, h, rect_id)
# bin_index: Qual chapa foi usada (se usou mais de uma)
# x, y: Coordenadas do canto inferior esquerdo
resultados_processados = packer.rect_list()

if not resultados_processados:
    print("Nenhuma peça foi encaixada. Verifique as dimensões da chapa vs as peças.")
else:
    print(f"Total de peças encaixadas: {len(resultados_processados)}")
    for rect in resultados_processados:
        b, x, y, w, h, rid = rect
        print(f"Peça {rid}: Encaixada na chapa {b} em (X={x}, Y={y}) com tamanho {w}x{h}")

# [Gerar Ilustração Visual]
resultado = otimizar_corte(pecas_projeto, chapa_15mm['w'], chapa_15mm['h'])

for rect in resultado:
    b, x, y, w, h, rid = rect
    print(f"Peça {rid}: Posição (X={x}, Y={y}) | Tamanho {w}x{h}")
